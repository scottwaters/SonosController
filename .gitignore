# Defense-in-depth — secret/key patterns that should never be committed.
# Nothing matching currently exists in the tree; these prevent accidental
# adds if a developer ever drops a cert or env file into the repo.
.env
.env.local
.env.*.local
*.p12
*.pem
*.cer
*.key
*.keystore
.release.env

# ForFunView.swift is local-only again while the visualisations get
# reworked. The file isn't in project.pbxproj's source list, so the
# build succeeds whether or not it exists on disk. Restore by adding
# the file ref + build entry back into project.pbxproj when ready.
Choragus/Views/ForFunView.swift
